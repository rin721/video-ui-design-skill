{
  "meta": {
    "name": "ui-design-skill-tokens",
    "version": "1.0.0",
    "description": "Reusable semantic design tokens for original website generation."
  },
  "color": {
    "primitive": {
      "neutral_0": "#ffffff",
      "neutral_50": "#fbfcfe",
      "neutral_100": "#f4f7fa",
      "neutral_200": "#e7ecf2",
      "neutral_300": "#cfd8e3",
      "neutral_400": "#9aa8b6",
      "neutral_500": "#6b7785",
      "neutral_600": "#52616b",
      "neutral_700": "#344351",
      "neutral_800": "#1f2933",
      "neutral_900": "#111827",
      "brand_50": "#fff1f5",
      "brand_100": "#ffe3eb",
      "brand_200": "#ffc8d6",
      "brand_300": "#fa9eb8",
      "brand_400": "#ee6f92",
      "brand_500": "#d94a73",
      "brand_600": "#be3455",
      "brand_700": "#9f2846",
      "brand_800": "#7f233c",
      "accent_50": "#edfdf9",
      "accent_100": "#ccfbef",
      "accent_500": "#0f9f8f",
      "accent_700": "#0f766e",
      "info_500": "#2563eb",
      "success_500": "#177245",
      "warning_500": "#a15c00",
      "danger_500": "#b42318"
    },
    "semantic": {
      "light": {
        "bg_page": "#fbfcfe",
        "bg_surface": "#ffffff",
        "bg_surface_elevated": "rgba(255, 255, 255, 0.86)",
        "bg_inverse": "#111827",
        "text_primary": "#1f2933",
        "text_secondary": "#344351",
        "text_muted": "#52616b",
        "text_inverse": "#ffffff",
        "border_subtle": "#e7ecf2",
        "border_default": "#cfd8e3",
        "border_strong": "#9aa8b6",
        "action_primary": "#be3455",
        "action_primary_hover": "#9f2846",
        "action_secondary": "#edfdf9",
        "action_secondary_hover": "#ccfbef",
        "focus_ring": "#0f766e",
        "overlay": "rgba(17, 24, 39, 0.48)"
      },
      "dark": {
        "bg_page": "#111827",
        "bg_surface": "#1f2933",
        "bg_surface_elevated": "rgba(31, 41, 51, 0.9)",
        "bg_inverse": "#ffffff",
        "text_primary": "#f4f7fa",
        "text_secondary": "#cfd8e3",
        "text_muted": "#9aa8b6",
        "text_inverse": "#111827",
        "border_subtle": "#344351",
        "border_default": "#52616b",
        "border_strong": "#9aa8b6",
        "action_primary": "#fa9eb8",
        "action_primary_hover": "#ffc8d6",
        "action_secondary": "#0f766e",
        "action_secondary_hover": "#0f9f8f",
        "focus_ring": "#ccfbef",
        "overlay": "rgba(0, 0, 0, 0.62)"
      }
    },
    "state": {
      "success": "#177245",
      "warning": "#a15c00",
      "danger": "#b42318",
      "info": "#2563eb",
      "disabled_text": "#9aa8b6",
      "disabled_surface": "#f4f7fa"
    },
    "brandSwap": {
      "primary_scale": "replace brand_50 through brand_800 as one hue family",
      "secondary_scale": "replace accent_50 through accent_700 with a contrasting support hue",
      "contrast_floor": "maintain 4.5:1 for body text and 3:1 for large text and UI boundaries"
    }
  },
  "typography": {
    "font_family": {
      "display": "Inter, ui-sans-serif, system-ui, sans-serif",
      "body": "Inter, ui-sans-serif, system-ui, sans-serif",
      "mono": "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace"
    },
    "type_scale": {
      "display_lg": { "size": "3.75rem", "line_height": "1.08", "weight": "700", "letter_spacing": "0" },
      "display_md": { "size": "3rem", "line_height": "1.1", "weight": "700", "letter_spacing": "0" },
      "h1": { "size": "2.25rem", "line_height": "1.16", "weight": "700", "letter_spacing": "0" },
      "h2": { "size": "1.75rem", "line_height": "1.22", "weight": "650", "letter_spacing": "0" },
      "h3": { "size": "1.25rem", "line_height": "1.32", "weight": "650", "letter_spacing": "0" },
      "body_lg": { "size": "1.125rem", "line_height": "1.65", "weight": "400" },
      "body_md": { "size": "1rem", "line_height": "1.6", "weight": "400" },
      "body_sm": { "size": "0.875rem", "line_height": "1.5", "weight": "400" },
      "caption": { "size": "0.75rem", "line_height": "1.45", "weight": "500" },
      "label": { "size": "0.875rem", "line_height": "1.2", "weight": "650" }
    }
  },
  "spacing": {
    "space_0": "0",
    "space_1": "0.25rem",
    "space_2": "0.5rem",
    "space_3": "0.75rem",
    "space_4": "1rem",
    "space_5": "1.25rem",
    "space_6": "1.5rem",
    "space_8": "2rem",
    "space_10": "2.5rem",
    "space_12": "3rem",
    "space_16": "4rem",
    "space_20": "5rem"
  },
  "radius": {
    "radius_none": "0",
    "radius_sm": "0.25rem",
    "radius_md": "0.375rem",
    "radius_lg": "0.5rem",
    "radius_xl": "0.75rem",
    "radius_2xl": "1rem",
    "radius_full": "9999px"
  },
  "shadow": {
    "shadow_none": "none",
    "shadow_sm": "0 1px 2px rgba(17, 24, 39, 0.08)",
    "shadow_md": "0 4px 10px rgba(17, 24, 39, 0.12), 0 0 0 1px rgba(207, 216, 227, 0.5)",
    "shadow_lg": "0 14px 32px rgba(17, 24, 39, 0.16)",
    "shadow_focus": "0 0 0 3px rgba(15, 118, 110, 0.35), 0 2px 8px rgba(17, 24, 39, 0.12)"
  },
  "motion": {
    "duration": {
      "micro": "80ms",
      "short": "160ms",
      "medium": "240ms",
      "long": "420ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "enter": "cubic-bezier(0.16, 1, 0.3, 1)",
      "exit": "cubic-bezier(0.4, 0, 1, 1)",
      "emphasized": "cubic-bezier(0.19, 1, 0.22, 1)"
    }
  },
  "zIndex": {
    "z_base": 0,
    "z_dropdown": 100,
    "z_sticky": 200,
    "z_overlay": 300,
    "z_modal": 400,
    "z_toast": 500
  },
  "breakpoints": {
    "mobile": "0px",
    "tablet": "768px",
    "desktop": "1024px",
    "wide": "1280px"
  }
}
